{
  "info": {
    "name": "Drone Inspection Platform API Collection",
    "description": "Postman collection covering all core endpoints and advanced SaaS features of the Drone Inspection platform.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Create Inspection (Idempotent)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Idempotency-Key",
            "value": "7b5ef970-8e12-4212-9c12-32ba19e8cf12",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"organization_id\": \"{{organization_id}}\",\n  \"warehouse_id\": \"{{warehouse_id}}\",\n  \"drone_id\": \"{{drone_id}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/v1/inspections",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "v1",
            "inspections"
          ]
        }
      }
    },
    {
      "name": "2. Get Inspection (Time-Travel)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/v1/inspections/{{inspection_id}}?version=1",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "v1",
            "inspections",
            "{{inspection_id}}"
          ],
          "query": [
            {
              "key": "version",
              "value": "1"
            }
          ]
        }
      }
    },
    {

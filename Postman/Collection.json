          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/v1/inspections/{{inspection_id}}/upload-url",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "v1",
            "inspections",
            "{{inspection_id}}",
            "upload-url"
          ]
        }
      }
    },
